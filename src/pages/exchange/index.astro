---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import DarkHeader from '../../components/astro/DarkHeader.astro';
import DarkFooter from '../../components/astro/DarkFooter.astro';
import CategoryPills from '../../components/astro/CategoryPills.astro';
import PublisherCardDark from '../../components/astro/PublisherCardDark.astro';
import { fetchAllPublishers, fetchExchangeFeed } from '../../data/fetch';
import { getPublisherTenant } from '../../utils/constants';

const categoryParam = Astro.url.searchParams.get('category') || undefined;

const allPublishers = await fetchAllPublishers();

const filteredPublishers = categoryParam
  ? allPublishers.filter((p) => p.expertise.includes(categoryParam))
  : allPublishers;

const hasPublishers = filteredPublishers.length > 0;

const publisherCards = filteredPublishers.map((publisher) => ({
  name: publisher.name,
  role: publisher.role,
  expertise: publisher.expertise,
  description: publisher.description,
  avatarUrl: publisher.avatarUrl,
  color: publisher.color,
  subscribers: publisher.stats.totalViews,
  href: `/exchange/publisher/${publisher.slug}`,
}));

// Build tenant content URL for a feed item
function getTenantContentUrl(item: { type: string; listType?: string; id: string; publisherSlug: string }) {
  const tenant = getPublisherTenant(item.publisherSlug);
  const base = `https://${tenant}.heartbeatintel.com`;
  if (item.type === 'article') return `${base}/library/${item.id}?ref=exchange`;
  return `${base}/lists/${item.listType || 'library'}/${item.id}?ref=exchange`;
}

// Fetch recent content from all publishers
const feedItems = await fetchExchangeFeed(allPublishers);
const hasFeed = feedItems.length > 0;

// Aggregate stats across all publishers (not filtered)
const totalPublishers = allPublishers.length;
const totalLists = allPublishers.reduce((sum, p) => sum + (p.stats?.lists || 0), 0);
const totalArticles = allPublishers.reduce((sum, p) => sum + (p.stats?.articles || 0), 0);

const publisherCount = filteredPublishers.length;
const pageDescription = `Browse ${publisherCount} intelligence publishers on the Heartbeat Exchange. Subscribe to curated research, market analysis, and proprietary data from verified providers.`;
---

<BaseLayout
  title="Heartbeat Intelligence Exchange — Curated Research & Market Intelligence"
  description={pageDescription}
>
  <DarkHeader variant="exchange" maxWidth="1400px" />

  <main class="pt-16">
    <!-- Header -->
    <section class="max-w-[1400px] mx-auto px-6 pt-10 pb-6" id="publishers" aria-labelledby="exchange-heading">
      <header class="mb-6 max-w-2xl">
        <h1 id="exchange-heading" class="text-3xl md:text-4xl font-bold text-[var(--hb-text-primary)] tracking-tight mb-3">
          Intelligence Exchange
        </h1>
        <p class="text-base text-[var(--hb-text-primary)]/40 leading-relaxed">
          Subscribe to curated intelligence from verified publishers. Get exclusive research, proprietary data, and real-time market insights delivered to your workspace.
        </p>
      </header>

      <!-- Stats -->
      <div class="flex flex-wrap items-center gap-6 mb-8 py-4 border-y border-[var(--hb-border)]">
        <div class="flex items-center gap-2">
          <span class="text-xl font-bold text-[var(--hb-text-primary)]">{totalPublishers}</span>
          <span class="text-sm text-[var(--hb-text-primary)]/40">Publishers</span>
        </div>
        <div class="h-5 w-px bg-[var(--hb-border)]"></div>
        <div class="flex items-center gap-2">
          <span class="text-xl font-bold text-[var(--hb-text-primary)]">{totalLists}</span>
          <span class="text-sm text-[var(--hb-text-primary)]/40">Publications</span>
        </div>
        <div class="h-5 w-px bg-[var(--hb-border)]"></div>
        <div class="flex items-center gap-2">
          <span class="text-xl font-bold text-[var(--hb-text-primary)]">{totalArticles}</span>
          <span class="text-sm text-[var(--hb-text-primary)]/40">Articles</span>
        </div>
      </div>

      <!-- Category filter -->
      <div class="mb-8">
        <CategoryPills activeCategory={categoryParam} />
      </div>

      <!-- Publisher grid -->
      {hasPublishers ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {publisherCards.map((card) => (
            <div class="reveal">
              <PublisherCardDark
                name={card.name}
                role={card.role}
                expertise={card.expertise}
                description={card.description}
                avatarUrl={card.avatarUrl}
                color={card.color}
                subscribers={card.subscribers}
                href={card.href}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="glass-card p-8 text-center">
          <p class="text-sm text-[var(--hb-text-primary)]/40">No publishers found for this category.</p>
        </div>
      )}
    </section>

    <!-- Recent Publications Feed -->
    {hasFeed && (
      <section class="max-w-[1400px] mx-auto px-6 pt-4 pb-10">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-px flex-1 bg-[var(--hb-border)]"></div>
          <h2 class="text-xs font-bold text-[var(--hb-text-primary)]/30 uppercase tracking-widest">Latest from the Exchange</h2>
          <div class="h-px flex-1 bg-[var(--hb-border)]"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {feedItems.slice(0, 12).map((item) => (
            <a
              href={getTenantContentUrl(item)}
              class="group flex items-start gap-4 p-4 rounded-lg border border-[var(--hb-border)] hover:border-[var(--hb-border-hover,var(--hb-border))] hover:bg-[var(--hb-bg-secondary)] transition-all duration-200"
            >
              <div
                class="w-1 self-stretch rounded-full shrink-0"
                style={`background-color: ${item.publisherColor}`}
              ></div>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-[var(--hb-text-primary)] group-hover:text-[var(--hb-text-primary)] leading-snug mb-1 truncate">
                  {item.title}
                </h3>
                {item.description && (
                  <p class="text-xs text-[var(--hb-text-primary)]/30 leading-relaxed mb-2 line-clamp-2">{item.description}</p>
                )}
                <div class="flex items-center gap-2">
                  <span class="text-xs font-medium" style={`color: ${item.publisherColor}`}>{item.publisherName}</span>
                  <span class="text-[10px] text-[var(--hb-text-primary)]/20">·</span>
                  <span class="text-xs text-[var(--hb-text-primary)]/20 capitalize">{item.type}</span>
                  {item.date && (
                    <>
                      <span class="text-[10px] text-[var(--hb-text-primary)]/20">·</span>
                      <span class="text-xs text-[var(--hb-text-primary)]/20">{item.date}</span>
                    </>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <DarkFooter maxWidth="1400px" />
</BaseLayout>

<script>
  // Inject current theme into all outbound tenant links so workspace matches exchange theme
  function syncThemeToLinks() {
    const theme = localStorage.getItem('hb-theme') || 'light';
    document.querySelectorAll('a[href*="heartbeatintel.com/lists/"], a[href*="heartbeatintel.com/library/"]').forEach((a) => {
      const url = new URL(a.getAttribute('href')!, window.location.origin);
      url.searchParams.set('theme', theme);
      a.setAttribute('href', url.toString());
    });
  }
  syncThemeToLinks();
  const observer = new MutationObserver(() => syncThemeToLinks());
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
</script>
