---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import DarkHeader from '../../../../components/astro/DarkHeader.astro';
import DarkFooter from '../../../../components/astro/DarkFooter.astro';
import Avatar from '../../../../components/ui/Avatar.astro';
import Badge from '../../../../components/ui/Badge.astro';
import SubscribeModalWrapper from '../../../../components/react/SubscribeModalWrapper';
import { CONTENT_DATA, getPublisherTenant, API_BASE_URL } from '../../../../utils/constants';
import { fetchPublisherProfile, fetchPublisherContent } from '../../../../data/fetch';

export const prerender = false;

const publisherId = Astro.params.publisherId!;

const publisher = await fetchPublisherProfile(publisherId);
const content = await fetchPublisherContent(publisherId);

if (!publisher) {
  return Astro.redirect('/exchange');
}

const staticContent = CONTENT_DATA[publisherId] || { lists: [], articles: [] };
const lists = content?.lists?.length ? content.lists : staticContent.lists;
const articles = content?.articles?.length ? content.articles : staticContent.articles;
const allPulses = [...lists.map(l => ({ ...l, _type: 'list' as const })), ...articles.map(a => ({ ...a, _type: 'article' as const }))].sort((a, b) => {
  if (!a.date && !b.date) return 0;
  if (!a.date) return 1;
  if (!b.date) return -1;
  return new Date(b.date).getTime() - new Date(a.date).getTime();
});
---

<BaseLayout
  title={`${publisher.name} - Heartbeat Intelligence`}
  description={publisher.description}
  ogImage={publisher.avatarUrl || '/images/logos/heartbeatLogoBlack.svg'}
>
  <!-- Header -->
  <DarkHeader
    variant="publisher"
    showBack={true}
    backHref="/exchange"
    backLabel="Exchange"
    maxWidth="1200px"
  />

  <!-- Hero Section -->
  <section class="pt-16">
    <div
      class="publisher-hero py-12 border-b border-[var(--hb-border)] relative overflow-hidden"
      data-publisher-color={publisher.color}
    >
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-[280px_1fr] gap-8 items-start reveal">
          <!-- Profile Card -->
          <div class="publisher-profile-card glass-card p-6 flex flex-col items-center gap-4">
            <Avatar
              src={publisher.avatarUrl}
              alt={publisher.name}
              size="2xl"
              borderColor={publisher.color}
              borderWidth={4}
            />
            <div class="text-center">
              <h1 class="text-2xl font-bold text-[var(--hb-text-primary)]">{publisher.name}</h1>
              <p class="text-sm text-[var(--hb-text-tertiary)] mt-1">{publisher.role}</p>
              {publisher.expertise.length > 0 && (
                <div class="flex flex-wrap gap-1 mt-2 justify-center">
                  {publisher.expertise.slice(0, 3).map((tag) => (
                    <span
                      class="px-2 py-0.5 rounded-full text-[11px] font-semibold"
                      style={`background-color: ${publisher.color}15; color: ${publisher.color};`}
                    >
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>

            <!-- Subscribe Button -->
            <button
              id="subscribe-btn"
              class="w-full py-2.5 px-4 text-white font-semibold rounded-lg flex items-center justify-center gap-2 transition-opacity hover:opacity-90"
              style={`background-color: ${publisher.color}`}
            >
              Subscribe to Intel
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>

            <!-- Follow (saves to Heartbeat account) -->
            <button
              id="follow-btn"
              class="mt-2 w-full py-2 px-4 text-sm font-medium rounded-lg border border-white/10 text-white/70 hover:bg-white/5 hover:text-white transition-colors"
            >
              + Follow
            </button>
          </div>

          <!-- Bio & Expertise -->
          <div class="flex flex-col gap-6">
            <div>
              <h2 class="text-[32px] font-bold text-[var(--hb-text-primary)] tracking-tight mb-3">
                About {publisher.name.split(' ')[0]}
              </h2>
              <p class="text-[17px] text-[var(--hb-text-secondary)] leading-relaxed">{publisher.longBio}</p>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pulses -->
  <section class="max-w-[1200px] mx-auto px-6 py-10">
    <div class="flex items-center gap-3 mb-8">
      <h2 class="text-lg font-bold text-[var(--hb-text-primary)] flex items-center gap-3">
        <!-- Pulsating dot -->
        <span class="relative flex h-3 w-3">
          <span class="pulse-ring absolute inline-flex h-full w-full rounded-full opacity-75" style={`background-color: ${publisher.color}`}></span>
          <span class="relative inline-flex rounded-full h-3 w-3" style={`background-color: ${publisher.color}`}></span>
        </span>
        Pulses
        <span class="text-xs font-normal text-[var(--hb-text-primary)]/30">{allPulses.length}</span>
      </h2>
      <!-- Animated heartbeat line -->
      <div class="flex-1 h-px relative overflow-hidden ml-2">
        <div class="absolute inset-0 bg-[var(--hb-border)]"></div>
        <div class="heartbeat-line absolute h-full w-24" style={`background: linear-gradient(90deg, transparent, ${publisher.color}60, transparent)`}></div>
      </div>
    </div>

    {allPulses.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {allPulses.map((item, i) => {
          const tenant = getPublisherTenant(publisherId);
          const href = item._type === 'article'
            ? `https://${tenant}.heartbeatintel.com/library/${item.id}?ref=exchange&publisher=${publisherId}`
            : `https://${tenant}.heartbeatintel.com/lists/${item.listType || 'library'}/${item.id}?ref=exchange&publisher=${publisherId}`;
          const isExternal = true;
          return (
            <a
              href={href}
              target={isExternal ? '_blank' : undefined}
              rel={isExternal ? 'noopener noreferrer' : undefined}
              class="pulse-card group relative bg-white/[0.03] rounded-xl p-5 border border-white/[0.06] transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-white/[0.12] hover:shadow-lg hover:shadow-black/20 block overflow-hidden"
              style={`animation-delay: ${i * 80}ms`}
            >
              <!-- Accent bar on left -->
              <div class="absolute left-0 top-0 bottom-0 w-[3px] rounded-l-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300" style={`background-color: ${publisher.color}`}></div>

              <div class="flex items-start justify-between mb-3">
                <div class="flex items-center gap-2">
                  <!-- Mini pulse dot per card -->
                  <span class="inline-flex h-1.5 w-1.5 rounded-full" style={`background-color: ${publisher.color}`}></span>
                  <span class="text-[11px] text-white/30 font-semibold uppercase tracking-wide">
                    {item._type === 'list' ? 'list' : 'article'}
                  </span>
                </div>
                <div class="flex items-center gap-2">
                  {item.isHot && (
                    <span class="bg-red-500/15 text-red-400 text-[10px] font-semibold px-2 py-0.5 rounded-full animate-pulse">HOT</span>
                  )}
                  {item.isPremium && (
                    <span class="bg-amber-500/15 text-amber-400 text-[10px] font-semibold px-2 py-0.5 rounded-full">PREMIUM</span>
                  )}
                </div>
              </div>
              <h3 class="text-[17px] font-semibold text-white mb-2 leading-snug group-hover:text-white transition-colors">{item.title}</h3>
              <p class="text-sm text-white/40 mb-4 leading-relaxed line-clamp-2">{item.description}</p>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-4 text-[13px] text-white/30">
                  {item.date && <span>{item.date}</span>}
                  {item.date && item.readTime && <span>&bull;</span>}
                  {item.readTime && <span>{item.readTime}</span>}
                </div>
                <div class="flex items-center gap-1 text-[12px] opacity-0 group-hover:opacity-100 transition-all duration-200 translate-x-1 group-hover:translate-x-0" style={`color: ${publisher.color}`}>
                  <span>{isExternal ? 'Open in workspace' : 'Read'}</span>
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="glass-card p-8 text-center">
        <span class="relative flex h-4 w-4 mx-auto mb-3">
          <span class="pulse-ring absolute inline-flex h-full w-full rounded-full opacity-75 bg-white/20"></span>
          <span class="relative inline-flex rounded-full h-4 w-4 bg-white/20"></span>
        </span>
        <p class="text-sm text-[var(--hb-text-primary)]/40">No pulses yet.</p>
      </div>
    )}
  </section>

  <style>
    @keyframes pulse-ring {
      0% { transform: scale(1); opacity: 0.75; }
      70% { transform: scale(2.5); opacity: 0; }
      100% { transform: scale(2.5); opacity: 0; }
    }
    .pulse-ring {
      animation: pulse-ring 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    @keyframes heartbeat-sweep {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(1200%); }
    }
    .heartbeat-line {
      animation: heartbeat-sweep 3s ease-in-out infinite;
    }

    @keyframes pulse-fade-in {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .pulse-card {
      animation: pulse-fade-in 0.4s ease-out both;
    }
  </style>

  <DarkFooter maxWidth="1200px" />

  <!-- Subscribe Modal -->
  <SubscribeModalWrapper client:load />
</BaseLayout>

<script define:vars={{ publisherUuid: publisher.id, publisherName: publisher.name, publisherColor: publisher.color, monthlyPriceCents: publisher.monthlyPriceCents, yearlyPriceCents: publisher.yearlyPriceCents, billingOptions: publisher.billingOptions }}>
  const subscribeBtn = document.getElementById('subscribe-btn');

  if (subscribeBtn) {
    subscribeBtn.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('openSubscribeModal', {
        detail: { publisherId: publisherUuid, publisherName, publisherColor, monthlyPriceCents, yearlyPriceCents, billingOptions }
      }));
    });
  }
</script>

<script>
  // Inject current theme + Exchange bridge token into all outbound tenant links.
  function enhanceTenantLinks() {
    const theme = localStorage.getItem('hb-theme') || 'dark';
    const bridge = localStorage.getItem('exchange_access_token') || '';
    document.querySelectorAll('a[href*="heartbeatintel.com/lists/"], a[href*="heartbeatintel.com/library/"]').forEach((a) => {
      const url = new URL(a.getAttribute('href')!, window.location.origin);
      url.searchParams.set('theme', theme);
      if (bridge) url.searchParams.set('bridge', bridge);
      a.setAttribute('href', url.toString());
    });
  }
  enhanceTenantLinks();
  const observer = new MutationObserver(() => enhanceTenantLinks());
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  window.addEventListener('storage', (e) => {
    if (e.key === 'exchange_access_token') enhanceTenantLinks();
  });

  // Track clicks into reading history (Exchange-side, localStorage-backed).
  const HIST_KEY = 'hb_reading_history';
  document.querySelectorAll<HTMLAnchorElement>('.pulse-card').forEach((a) => {
    a.addEventListener('click', () => {
      try {
        const title = a.querySelector('h3')?.textContent?.trim() || a.href;
        const kind = a.querySelector('span.uppercase')?.textContent?.trim() === 'list' ? 'list' : 'article';
        const publisher = document.querySelector<HTMLElement>('[data-publisher-name]')?.dataset.publisherName
          || window.location.pathname.split('/').pop() || '';
        const hist = JSON.parse(localStorage.getItem(HIST_KEY) || '[]');
        const next = [{ href: a.href, title, publisher, ts: Date.now(), kind }, ...hist.filter((x: any) => x.href !== a.href)].slice(0, 50);
        localStorage.setItem(HIST_KEY, JSON.stringify(next));
      } catch { /* ignore */ }
    });
  });

  // Follow / unfollow this publisher (localStorage).
  const PREFS_KEY = 'hb_prefs';
  const publisherSlug = window.location.pathname.split('/').filter(Boolean).pop() || '';
  const followBtn = document.getElementById('follow-btn');
  function getPrefs() {
    try { return JSON.parse(localStorage.getItem(PREFS_KEY) || '{}'); } catch { return {}; }
  }
  function isFollowing() {
    const p = getPrefs();
    return Array.isArray(p.follow) && p.follow.includes(publisherSlug);
  }
  function renderFollowBtn() {
    if (!followBtn) return;
    followBtn.textContent = isFollowing() ? '✓ Following' : '+ Follow';
    followBtn.classList.toggle('bg-white/10', isFollowing());
  }
  followBtn?.addEventListener('click', () => {
    const p = getPrefs();
    const set = new Set(p.follow || []);
    if (set.has(publisherSlug)) set.delete(publisherSlug);
    else set.add(publisherSlug);
    localStorage.setItem(PREFS_KEY, JSON.stringify({ ...p, follow: Array.from(set) }));
    renderFollowBtn();
  });
  renderFollowBtn();
</script>
