---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  theme?: 'dark' | 'light';
}

const {
  title,
  description = 'Trade in intelligence, not just information. Connect with publishers who curate and monetize exclusive intel.',
  ogImage = '/images/logos/heartbeatLogoBlack.svg',
  ogType = 'website',
  theme = 'light',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, 'https://www.heartbeatintel.com').toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, 'https://www.heartbeatintel.com').toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Heartbeat Intelligence" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/images/logos/heartbeatLogoBlack.svg" />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-DYXQ5WQC47"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-DYXQ5WQC47');
    </script>

    <!-- Preconnect for external resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.iconify.design" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('hb-theme');
        var theme = stored === 'dark' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class="min-h-screen bg-[var(--hb-bg-primary)] text-[var(--hb-text-primary)]">
    <div class="noise-overlay"></div>
    <slot />
    <script src="../scripts/reveal.ts"></script>
    <script src="../scripts/theme.ts"></script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
